{
    "manifest_version": 3, 
    "name": "Tab Summarizer", 
    "version": "1.0",
    "description": "Summarize any webpage instantly using AI",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Summarize this page"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"], 
            "js": ["content.js"]
        }
    ]
}